{
  "name": "softer-volumes",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "postinstall": "prisma generate",
    "lint": "next lint",
    "type-check": "next typegen && tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate:deploy": "dotenv -e .env -- prisma migrate deploy",
    "db:migrate:diff": "dotenv -e .env -- sh -c 'prisma migrate diff --from-url \"$DIRECT_URL\" --to-schema-datamodel prisma/schema.prisma --script'",
    "db:push": "dotenv -e .env -- prisma db push",
    "db:seed": "dotenv -e .env -- node prisma/seed.js"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.7.4",
    "@prisma/client": "^5.22.0",
    "@reduxjs/toolkit": "^2.4.0",
    "@stripe/stripe-js": "^4.9.0",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.104.0",
    "clsx": "^2.1.1",
    "framer-motion": "^11.15.0",
    "lucide-react": "^0.468.0",
    "mapbox-gl": "^3.8.0",
    "next": "^16.2.4",
    "next-auth": "^5.0.0-beta.25",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-intersection-observer": "^9.13.1",
    "react-map-gl": "^7.1.7",
    "react-redux": "^9.1.2",
    "resend": "^4.0.1",
    "sharp": "^0.33.5",
    "stripe": "^17.4.0",
    "tailwind-merge": "^2.5.5",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/mapbox-gl": "^3.4.1",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "dotenv-cli": "^7.4.4",
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.2.4",
    "postcss": "^8.4.49",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2"
  }
}
